# MongoDB Atlas connection string
# Get this from Atlas -> Connect -> Drivers (looks like below, with your real user/password/db name)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/resume_screener?retryWrites=true&w=majority

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Which Gemini model to use for screening
GEMINI_MODEL=gemini-2.5-flash

# Server port
PORT=5000

# Frontend origin allowed to call this API (for CORS)
CLIENT_ORIGIN=http://localhost:5173
